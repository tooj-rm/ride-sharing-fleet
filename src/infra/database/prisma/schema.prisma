// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum DriverStatus {
  available
  on_trip
  offline
}

enum RideStatus {
  requested
  accepted
  in_progress
  completed
  cancelled
}

model Driver {
  id          String       @id @db.VarChar(50)
  name        String       @db.VarChar(100)
  status      DriverStatus
  currentRide String?      @db.VarChar(50)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Ride {
  id        String     @id @db.VarChar(50)
  riderId   String     @db.VarChar(50)
  pickupLat Float
  pickupLng Float
  dropOfLat Float
  dropOfLng Float
  status    RideStatus
  driverId  String?    @db.VarChar(50)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
